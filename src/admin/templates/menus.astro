---
import AdminLayout from "../layouts/AdminLayout.astro";
import ContentEditorSidebar from "../components/ContentEditorSidebar.astro";
import ContentFormNotification from "../components/ContentFormNotification.astro";
import CustomFieldsWrapper from "../components/CustomFieldsWrapper.astro";
import { db } from "../../db/index.ts";
import type { MenuItem } from "../../utils/menu.ts";
import {
  getContentPageData,
  isContentPageRedirect,
} from "../../core/services/content-page-data.ts";
import { t, type Locale } from "../../i18n/index.ts";

export interface Props {
  locale: string;
  postTypeSlug: string;
  action: string;
  idParam: string | null;
  menuItems: MenuItem[];
  currentUser: {
    id?: string;
    email?: string;
    name?: string;
  };
}

const { locale, postTypeSlug, action, idParam, menuItems, currentUser } = Astro.props;
const currentLocale = locale as Locale;
const isEdit = action === "edit";
const asideAccordionName = "menus-aside";

const result = await getContentPageData({
  db,
  locale,
  postTypeSlug,
  action,
  idParam,
  userId: String(currentUser?.id ?? ""),
});

if (isContentPageRedirect(result)) {
  return Astro.redirect(result.url);
}

const pageTitle = result.pageTitle;
const initialTitle = result.initialTitle;
const initialSlug = result.initialSlug;
const initialStatus = result.initialStatus || "draft";
const initialAuthorId = result.initialAuthorId;
const initialLocaleId = result.initialLocaleId;
const postId = result.post?.id ?? null;
const hasCustomFields = result.hasCustomFields;
const initialCustomFields = result.initialCustomFields;
const templateCustomFieldsList = result.templateCustomFieldsList;

const menuLabels = {
  customOption: t(currentLocale, "admin.menus.customOption"),
  customName: t(currentLocale, "admin.menus.customName"),
  customUrl: t(currentLocale, "admin.menus.customUrl"),
  order: t(currentLocale, "admin.menus.order"),
  searchPosts: t(currentLocale, "admin.menus.searchPosts"),
  addItem: t(currentLocale, "admin.menus.addItem"),
  remove: t(currentLocale, "admin.menus.remove"),
  typePost: t(currentLocale, "admin.menus.typePost"),
  typeCustom: t(currentLocale, "admin.menus.typeCustom"),
  typeTaxonomy: t(currentLocale, "admin.menus.typeTaxonomy"),
  selectPost: t(currentLocale, "admin.menus.selectPost"),
  parentMenu: t(currentLocale, "admin.menus.parentMenu"),
  noParent: t(currentLocale, "admin.menus.noParent"),
  sortAlphabetical: t(currentLocale, "admin.menus.sortAlphabetical"),
  sortCreation: t(currentLocale, "admin.menus.sortCreation"),
  displayTitle: t(currentLocale, "admin.menus.displayTitle"),
  displayThumbnail: t(currentLocale, "admin.menus.displayThumbnail"),
  displayExcerpt: t(currentLocale, "admin.menus.displayExcerpt"),
  submenuOptions: t(currentLocale, "admin.menus.submenuOptions"),
  submenuSort: t(currentLocale, "admin.menus.submenuSort"),
  submenuDisplay: t(currentLocale, "admin.menus.submenuDisplay"),
};

const initialMenuItemsJson = JSON.stringify(
  result.initialMenuItems.map((item, index) => ({
    clientId: `menu-${item.id ?? index}`,
    parentClientId: item.parent_menu_item_id
      ? `menu-${item.parent_menu_item_id}`
      : null,
    parentMenuItemId: item.parent_menu_item_id ?? null,
    submenu_sort: item.submenu_sort ?? "creation",
    submenu_display: item.submenu_display ?? ["title"],
    ...item,
  })),
);
---

<AdminLayout title={pageTitle} locale={locale} menuItems={menuItems} user={currentUser}>
  <script
    define:vars={{
      initialTitle: String(initialTitle || ""),
      initialSlug: String(initialSlug || ""),
      initialExcerpt: "",
      initialStatus: String(initialStatus || "draft"),
      initialAuthorId: String(initialAuthorId || ""),
      thumbnailPath: "",
      thumbnailUrl: "",
      initialThumbnailAttachmentId: 0,
      locale,
      initialMenuItems: initialMenuItemsJson,
      menuLabels,
    }}
  >
    window.__menusFormProps = {
      initialTitle,
      initialSlug,
      initialExcerpt,
      initialStatus,
      initialAuthorId,
      thumbnailPath,
      thumbnailUrl,
      initialThumbnailAttachmentId,
      locale,
      initialMenuItems: JSON.parse(initialMenuItems),
      labels: menuLabels,
    };
  </script>
  <script>
    import "../../shared/scripts/menus-form-init.ts";
  </script>

  <div class="flex-1 flex flex-col min-h-0 py-6 pl-6 pr-0">
    <form
      method="post"
      action="/api/posts"
      class="flex flex-col gap-4 w-full min-h-0 flex-1 menus-form"
      x-data="menusForm"
      data-is-edit={String(isEdit)}
      x-init="if ($el.dataset.isEdit !== 'true') slug = (window.slugify && window.slugify(title)) || ''"
    >
      <ContentFormNotification />
      <div id="content-form-error" class="mr-6 min-h-[1.5rem]" aria-live="polite"></div>

      <div class="flex gap-6 w-full min-h-0 flex-1">
        <input type="hidden" name="post_type" value={postTypeSlug} />
        <input type="hidden" name="action" value={action} />
        {postId && <input type="hidden" name="id" value={postId} />}
        <input type="hidden" name="locale" value={locale} />
        <input type="hidden" name="menu_items_data" value="" />

        <div class="flex-1 min-w-0 flex flex-col gap-4 min-h-0">
          <div class="form-control">
            <label for="menu-title" class="label">
              <span class="label-text">{t(currentLocale, "admin.list.titleColumn")}</span>
            </label>
            <input
              id="menu-title"
              type="text"
              name="title"
              class="input input-bordered w-full"
              required
              x-model="title"
              @input="slug = (window.slugify && window.slugify(title)) || ''"
              value={initialTitle}
            />
          </div>

          <div class="border border-base-300 rounded-box p-4 flex flex-col gap-4">
            <h2 class="text-lg font-semibold">{t(currentLocale, "admin.menus.itemsTitle")}</h2>

            <div class="flex flex-col gap-3" id="menu-items-tree" x-ref="rootList">
              <template x-for="root in rootItems()" :key="root.clientId">
                <div
                  class="menu-root-block border border-base-300 rounded-lg p-3 bg-base-100 flex flex-col gap-2"
                  :data-id="root.clientId"
                >
                  <div class="flex items-start gap-2">
                    <button
                      type="button"
                      class="drag-handle btn btn-ghost btn-xs btn-square shrink-0 cursor-grab active:cursor-grabbing mt-0.5"
                      aria-label="Reorder"
                      tabindex="-1"
                    >
                      ⠿
                    </button>
                    <div class="flex-1 min-w-0 flex flex-col gap-2">
                      <div class="flex items-start justify-between gap-2">
                        <div class="flex-1 min-w-0">
                          <p class="font-medium truncate" x-text="root.label"></p>
                          <p class="text-xs text-base-content/60 font-mono truncate">
                            <span x-text="itemTypeLabel(root)"></span>
                            <span x-show="root.link_type === 'post'">
                              · <span x-text="root.target_post_type"></span> · <span x-text="root.target_slug"></span>
                            </span>
                            <span x-show="root.link_type === 'taxonomy'">
                              · <span x-text="root.target_taxonomy_type"></span> · <span x-text="root.target_slug"></span>
                            </span>
                            <span x-show="root.link_type === 'custom'">
                              · <span x-text="root.custom_url"></span>
                            </span>
                          </p>
                        </div>
                        <button
                          type="button"
                          class="btn btn-ghost btn-xs btn-circle shrink-0"
                          :aria-label="labels.remove"
                          @click="removeItem(root.clientId)"
                        >
                          ✕
                        </button>
                      </div>
                      <div class="form-control max-w-[8rem]">
                        <label class="label py-0">
                          <span class="label-text text-xs" x-text="labels.order"></span>
                        </label>
                        <input
                          type="number"
                          min="1"
                          class="input input-bordered input-sm w-full"
                          :value="root.order"
                          @change="updateOrder(root.clientId, $event.target.value)"
                        />
                      </div>
                      <div
                        x-show="hasChildren(root.clientId)"
                        class="border border-base-300 rounded-md p-3 bg-base-200/40 flex flex-col gap-3"
                      >
                        <p class="text-sm font-medium" x-text="labels.submenuOptions"></p>
                        <fieldset class="flex flex-col gap-1">
                          <legend class="text-xs font-medium mb-1" x-text="labels.submenuSort"></legend>
                          <label class="label cursor-pointer justify-start gap-2 py-0">
                            <input
                              type="radio"
                              class="radio radio-sm"
                              :name="'submenu_sort_' + root.clientId"
                              value="alphabetical"
                              :checked="root.submenu_sort === 'alphabetical'"
                              @change="setSubmenuSort(root.clientId, 'alphabetical')"
                            />
                            <span class="label-text text-xs" x-text="labels.sortAlphabetical"></span>
                          </label>
                          <label class="label cursor-pointer justify-start gap-2 py-0">
                            <input
                              type="radio"
                              class="radio radio-sm"
                              :name="'submenu_sort_' + root.clientId"
                              value="creation"
                              :checked="root.submenu_sort === 'creation'"
                              @change="setSubmenuSort(root.clientId, 'creation')"
                            />
                            <span class="label-text text-xs" x-text="labels.sortCreation"></span>
                          </label>
                        </fieldset>
                        <fieldset class="flex flex-col gap-1">
                          <legend class="text-xs font-medium mb-1" x-text="labels.submenuDisplay"></legend>
                          <label class="label cursor-pointer justify-start gap-2 py-0">
                            <input
                              type="checkbox"
                              class="checkbox checkbox-sm"
                              :checked="(root.submenu_display || []).includes('title')"
                              @change="toggleSubmenuDisplay(root.clientId, 'title', $event.target.checked)"
                            />
                            <span class="label-text text-xs" x-text="labels.displayTitle"></span>
                          </label>
                          <label class="label cursor-pointer justify-start gap-2 py-0">
                            <input
                              type="checkbox"
                              class="checkbox checkbox-sm"
                              :checked="(root.submenu_display || []).includes('thumbnail')"
                              @change="toggleSubmenuDisplay(root.clientId, 'thumbnail', $event.target.checked)"
                            />
                            <span class="label-text text-xs" x-text="labels.displayThumbnail"></span>
                          </label>
                          <label class="label cursor-pointer justify-start gap-2 py-0">
                            <input
                              type="checkbox"
                              class="checkbox checkbox-sm"
                              :checked="(root.submenu_display || []).includes('excerpt')"
                              @change="toggleSubmenuDisplay(root.clientId, 'excerpt', $event.target.checked)"
                            />
                            <span class="label-text text-xs" x-text="labels.displayExcerpt"></span>
                          </label>
                        </fieldset>
                      </div>
                      <div
                        class="menu-children-list flex flex-col gap-2 mt-1 pl-2 border-l-4 border-l-primary/40 min-h-[2rem]"
                        :data-parent-client-id="root.clientId"
                        x-init="initChildrenSortable($el)"
                      >
                        <template x-for="child in childrenOf(root.clientId)" :key="child.clientId">
                          <div
                            class="menu-child-block border border-base-300 rounded-lg p-3 bg-base-200/30 flex flex-col gap-2"
                            :data-id="child.clientId"
                          >
                            <div class="flex items-start gap-2">
                              <button
                                type="button"
                                class="drag-handle btn btn-ghost btn-xs btn-square shrink-0 cursor-grab active:cursor-grabbing mt-0.5"
                                aria-label="Reorder"
                                tabindex="-1"
                              >
                                ⠿
                              </button>
                              <div class="flex-1 min-w-0 flex flex-col gap-2">
                                <div class="flex items-start justify-between gap-2">
                                  <div class="flex-1 min-w-0">
                                    <p class="font-medium truncate" x-text="child.label"></p>
                                    <p class="text-xs text-base-content/60 font-mono truncate">
                                      <span x-text="itemTypeLabel(child)"></span>
                                      <span x-show="child.link_type === 'post'">
                                        · <span x-text="child.target_post_type"></span> · <span x-text="child.target_slug"></span>
                                      </span>
                                      <span x-show="child.link_type === 'taxonomy'">
                                        · <span x-text="child.target_taxonomy_type"></span> · <span x-text="child.target_slug"></span>
                                      </span>
                                      <span x-show="child.link_type === 'custom'">
                                        · <span x-text="child.custom_url"></span>
                                      </span>
                                    </p>
                                  </div>
                                  <button
                                    type="button"
                                    class="btn btn-ghost btn-xs btn-circle shrink-0"
                                    :aria-label="labels.remove"
                                    @click="removeItem(child.clientId)"
                                  >
                                    ✕
                                  </button>
                                </div>
                                <div class="grid gap-3 sm:grid-cols-2">
                                  <div class="form-control">
                                    <label class="label py-0">
                                      <span class="label-text text-xs" x-text="labels.parentMenu"></span>
                                    </label>
                                    <select
                                      class="select select-bordered select-sm w-full"
                                      :value="child.parentClientId || ''"
                                      @change="setParent(child.clientId, $event.target.value || null)"
                                    >
                                      <option value="" x-text="labels.noParent"></option>
                                      <template x-for="parent in availableParents(child.clientId)" :key="parent.clientId">
                                        <option :value="parent.clientId" x-text="parent.label"></option>
                                      </template>
                                    </select>
                                  </div>
                                  <div class="form-control max-w-[8rem]">
                                    <label class="label py-0">
                                      <span class="label-text text-xs" x-text="labels.order"></span>
                                    </label>
                                    <input
                                      type="number"
                                      min="1"
                                      class="input input-bordered input-sm w-full"
                                      :value="child.order"
                                      @change="updateOrder(child.clientId, $event.target.value)"
                                    />
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </template>
                      </div>
                    </div>
                  </div>
                </div>
              </template>
            </div>

            <div
              x-show="showCustomForm"
              class="border border-primary/30 rounded-lg p-4 bg-primary/5 flex flex-col gap-3"
            >
              <div class="form-control">
                <label class="label">
                  <span class="label-text" x-text="labels.customName"></span>
                </label>
                <input type="text" class="input input-bordered w-full" x-model="customName" />
              </div>
              <div class="form-control">
                <label class="label">
                  <span class="label-text" x-text="labels.customUrl"></span>
                </label>
                <input type="text" class="input input-bordered w-full" x-model="customUrl" placeholder="https:// ou /caminho" />
              </div>
              <div class="flex gap-2">
                <button type="button" class="btn btn-primary btn-sm" @click="confirmCustomItem()">
                  {t(currentLocale, "admin.content.saveNew")}
                </button>
                <button type="button" class="btn btn-ghost btn-sm" @click="showCustomForm = false">
                  {t(currentLocale, "admin.content.cancel")}
                </button>
              </div>
            </div>

            <div
              x-show="pickerOpen"
              class="border border-base-300 rounded-lg p-3 bg-base-100 flex flex-col gap-2"
              @click.outside="pickerOpen = false"
            >
              <input
                type="text"
                class="input input-bordered input-sm w-full"
                :placeholder="labels.searchPosts"
                x-model="pickerSearch"
                @input.debounce.300ms="searchPosts()"
              />
              <ul class="menu menu-sm max-h-64 overflow-y-auto w-full p-0">
                <li>
                  <button type="button" class="font-medium text-primary" @click="chooseCustomOption()">
                    <span x-text="labels.customOption"></span>
                  </button>
                </li>
                <template x-if="pickerLoading">
                  <li><span class="text-base-content/60">{t(currentLocale, "admin.menus.loading")}</span></li>
                </template>
                <template x-for="result in pickerResults" :key="result.kind + '-' + result.id">
                  <li>
                    <button type="button" @click="selectPickerResult(result)">
                      <span class="font-medium" x-text="result.title"></span>
                      <span class="text-xs opacity-60 block font-mono" x-text="resultSubtitle(result)"></span>
                    </button>
                  </li>
                </template>
              </ul>
            </div>

            <div class="flex justify-center pt-2">
              <button
                type="button"
                class="btn btn-primary"
                @click="togglePicker()"
              >
                <span x-text="labels.addItem"></span>
              </button>
            </div>
          </div>

          {hasCustomFields && (
            <CustomFieldsWrapper
              initialData={initialCustomFields}
              templateCustomFields={templateCustomFieldsList}
            />
          )}
        </div>

        <ContentEditorSidebar
          locale={locale}
          asideAccordionName={asideAccordionName}
          action={action}
          users={result.users}
          initialLocaleId={initialLocaleId}
          initialParentId={null}
          parentPostOptions={[]}
          initialSlug={initialSlug}
          initialExcerpt=""
          initialOrder=""
          hasPostThumbnail={false}
          thumbnailUrl=""
          taxonomyBlocks={[]}
          selectedTermIds={[]}
          variant="menus"
        />
      </div>
    </form>
  </div>
</AdminLayout>
