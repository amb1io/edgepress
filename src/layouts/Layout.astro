---
import "../assets/app.css";
import HtmxLoader from "../components/HtmxLoader.astro";

interface Props {
  title: string;
  /** Script URL opcional (ex.: HTMX para login/setup) */
  headScript?: string;
}

const { title, headScript } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {headScript && <script src={headScript}></script>}
  </head>
  <body>
    {headScript && <HtmxLoader />}
    <slot />
  </body>
</html>
