{% comment %}
  Layout base do tema Edgepress.
  Tags do core disponíveis no <head> e no <body>:
  - {% seo_head %}       → title, meta, OG, Twitter, JSON-LD
  - {% theme_styles %}   → CSS do tema (assets/theme.css)
  - {% html_attrs %}     → lang="..."
  - {% body_class %}     → class="route-home ..."
  - {% scripts_footer %} → htmx, Alpine e theme.js
{% endcomment %}
<!doctype html>
<html {% html_attrs %}>
  <head>
    {% seo_head %}
    {% theme_styles %}
  </head>
  <body {% body_class %}>
    {% include 'parts/header' %}
    <main class="site-main">
      {% page_content %}
    </main>
    {% include 'parts/footer' %}
    {% scripts_footer %}
  </body>
</html>
