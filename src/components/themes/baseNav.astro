---
import { db } from "../../db/index.ts";
import { adminUrlLocaleToDbCode } from "../../utils/admin-locale-constants.ts";
import {
  loadPublishedMenusByLocation,
  type MenuItemPublicRaw,
} from "../../core/services/menu-items-service.ts";

type Props = {
  /** Slug do menu pai (location key). Ex: "primary" */
  menuSlug?: string;
  /** Ex: "pt-br" */
  locale: string;
  /** Classe opcional para o <nav> */
  className?: string;
  /** @deprecated Use menuSlug. Mantido para compatibilidade. */
  postType?: string;
};

const {
  menuSlug = "primary",
  locale,
  className,
} = Astro.props as Props;

const dbLocale = adminUrlLocaleToDbCode(locale);
let items: MenuItemPublicRaw[] = [];

try {
  const menusByLocation = await loadPublishedMenusByLocation(db, dbLocale);
  items = menusByLocation[menuSlug] ?? [];
} catch (err) {
  console.error("[edgepress][baseNav] Falha ao carregar menu", {
    menuSlug,
    locale,
    message: err instanceof Error ? err.message : String(err),
  });
}
---

<nav class={className}>
  <ul>
    {items.map((item) => (
      <li class:list={{ "has-submenu": item.children?.length }}>
        <a href={item.url}>{item.label}</a>
        {item.children?.length ? (
          <ul class="submenu">
            {item.children.map((child) => (
              <li>
                <a href={child.url}>{child.label}</a>
              </li>
            ))}
          </ul>
        ) : null}
      </li>
    ))}
  </ul>
</nav>
