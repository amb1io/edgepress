---
/**
 * Dropdown para selecionar post pai (hierarquia via posts.parent_id).
 * Wrapper fino sobre ParentSelectorDropdown.
 */
import ParentSelectorDropdown from "./ParentSelectorDropdown.astro";
import type { ParentItem } from "./ParentSelectorDropdown.astro";
import type { ParentPostOption } from "../core/services/content-page-data.ts";

export interface Props {
  parentPosts?: ParentPostOption[];
  selectedParentId?: number | null;
  fieldName?: string;
  searchPlaceholder?: string;
  noParentLabel?: string;
  selectPlaceholder?: string;
  noResultsLabel?: string;
  compact?: boolean;
}

const {
  parentPosts = [],
  selectedParentId = null,
  fieldName = "parent_id",
  searchPlaceholder = "Buscar post...",
  noParentLabel = "Sem pai",
  selectPlaceholder = "Selecione um post pai",
  noResultsLabel = "Nenhum post encontrado",
  compact = false,
} = Astro.props;

const items: ParentItem[] = parentPosts.map((post) => ({
  id: post.id,
  label: post.title,
  sublabel: `${post.post_type_slug} · ${post.slug}`,
}));
---

<ParentSelectorDropdown
  items={items}
  selectedId={selectedParentId}
  fieldName={fieldName}
  noParentValue=""
  searchPlaceholder={searchPlaceholder}
  noParentLabel={noParentLabel}
  selectPlaceholder={selectPlaceholder}
  noResultsLabel={noResultsLabel}
  compact={compact}
/>
