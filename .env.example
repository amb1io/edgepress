# URL pública do site (sitemap, SEO). Gravada em settings.site_url no seed se vazia.
SITE_URL=https://example.com

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# Better Auth - use .dev.vars for wrangler dev, wrangler secret put for production
BETTER_AUTH_SECRET=  # min 32 chars: openssl rand -base64 32
BETTER_AUTH_URL=     # e.g. http://localhost:8787 or https://your-domain.com
BETTER_AUTH_TRUSTED_ORIGINS=  # e.g. http://localhost:8787,https://your-domain.com

# Resend - email de recuperação de senha (opcional; se não definir, o link é logado no console em local)
RESEND_API_KEY=      # API key em https://resend.com/api-keys
RESEND_FROM=         # Remetente verificado no Resend, ex: "Edgepress <noreply@seudominio.com>"

# Rate Limiting - Optional configuration (default values are secure)
# Login rate limit
RATE_LIMIT_LOGIN_MAX=5           # Maximum attempts (default: 5)
RATE_LIMIT_LOGIN_WINDOW_MIN=15   # Window in minutes (default: 15)

# Register rate limit
RATE_LIMIT_REGISTER_MAX=3        # Maximum registrations (default: 3)
RATE_LIMIT_REGISTER_WINDOW_MIN=60  # Window in minutes (default: 60)

# Upload rate limit
RATE_LIMIT_UPLOAD_MAX=20         # Maximum uploads (default: 20)
RATE_LIMIT_UPLOAD_WINDOW_MIN=60  # Window in minutes (default: 60)

# General API rate limit
RATE_LIMIT_API_MAX=100           # Maximum requests (default: 100)
RATE_LIMIT_API_WINDOW_MIN=1      # Window in minutes (default: 1)

# Theme import & deploy (GitHub repository_dispatch)
# Repo that hosts .github/workflows (usually this app repo): owner/name
# Must be amb1io/edgepress (where theme-import-dispatch.yml lives), not the theme source repo.
THEME_IMPORT_DISPATCH_REPO=
# PAT with repo scope to trigger repository_dispatch on THEME_IMPORT_DISPATCH_REPO
THEME_IMPORT_GITHUB_TOKEN=
# GitHub event type for theme packaging workflow (default: theme_import_requested)
THEME_IMPORT_EVENT_TYPE=theme_import_requested
# GitHub event type for worker deploy after theme import (default: edgepress_deploy)
THEME_DEPLOY_EVENT_TYPE=edgepress_deploy
# Shared secret for POST /api/themes/import-callback (GitHub Actions → Worker)
THEME_IMPORT_CALLBACK_SECRET=
# Shared secret for GET /api/themes/active-package (deploy workflow → Worker)
THEME_PACKAGE_METADATA_SECRET=