{
  "name": "edgepress",
  "version": "0.0.1",
  "description": "A CMS WordPress compliant version that runs on the Edge",
  "keywords": [
    "cms",
    "wordpress",
    "cloudflare",
    "vercel",
    "edge"
  ],
  "homepage": "https://github.com/amb1io/edgepress#readme",
  "bugs": {
    "url": "https://github.com/amb1io/edgepress/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amb1io/edgepress.git"
  },
  "license": "ISC",
  "author": "Amb1.io",
  "type": "module",
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "main": "index.ts",
  "scripts": {
    "prebuild": "tsx scripts/collect-sitemap-urls.ts",
    "postbuild": "tsx scripts/generate-blocknote-public-manifest.ts",
    "build": "wrangler types -c wrangler.toml && astro build",
    "build:seed": "wrangler types -c wrangler.toml && tsx scripts/build-with-seed.ts && astro build",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler deploy --env preview",
    "dev:build": "npm run build && npx wrangler dev --port 8787",
    "setup:local": "tsx scripts/apply-edp-prefix-if-needed.ts && wrangler d1 migrations apply edgepress --local -c wrangler.toml && tsx scripts/seed-local.ts",
    "setup:remote": "tsx scripts/apply-edp-prefix-if-needed.ts --remote && wrangler d1 migrations apply edgepress --remote -c wrangler.toml && wrangler queues create edgepress-import -c wrangler.toml 2>/dev/null || true && wrangler queues create edgepress-import-dlq -c wrangler.toml 2>/dev/null || true && wrangler queues create edgepress-import-preview --env preview -c wrangler.toml 2>/dev/null || true && wrangler queues create edgepress-import-preview-dlq --env preview -c wrangler.toml 2>/dev/null || true && tsx scripts/generate-seed-sql.ts && wrangler d1 execute edgepress --remote --file=./drizzle/seed/seed-remote.sql -c wrangler.toml",
    "test": "vitest run"
  },
  "devDependencies": {
    "@astrojs/compiler-rs": "^0.1.6",
    "@astrojs/react": "^5.0.1",
    "@iconify-json/line-md": "^1.2.14",
    "@types/jquery": "^4.0.0",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/sortablejs": "^1.15.9",
    "drizzle-kit": "^0.31.8",
    "sass-embedded": "^1.98.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@astro-community/astro-embed-vimeo": "^0.3.12",
    "@astrojs/alpinejs": "^0.5.0",
    "@astrojs/cloudflare": "^13.1.2",
    "@astrojs/sitemap": "^3.7.2",
    "@blocknote/core": "^0.46.2",
    "@blocknote/mantine": "^0.46.2",
    "@blocknote/react": "^0.46.2",
    "@blocknote/xl-multi-column": "^0.46.2",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@libsql/client": "^0.15.15",
    "@mantine/core": "^8.3.11",
    "@mantine/hooks": "^8.3.11",
    "@mantine/utils": "^6.0.22",
    "@tailwindcss/vite": "^4.1.18",
    "@types/alpinejs": "^3.13.11",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/drag-drop": "^5.1.0",
    "@uppy/image-editor": "^4.2.0",
    "@uppy/locales": "^5.1.1",
    "@uppy/xhr-upload": "^5.1.1",
    "alpinejs": "^3.15.8",
    "astro": "^6.0.6",
    "astro-icon": "^1.1.5",
    "better-auth": "^1.4.9",
    "classnames": "^2.5.1",
    "daisyui": "^5.5.17",
    "datatables.net-dt": "^2.3.8",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "dropzone": "^6.0.0-beta.2",
    "fflate": "^0.8.3",
    "htmx.org": "^2.0.8",
    "jquery": "^4.0.0",
    "liquidjs": "^10.27.1",
    "nanotar": "^0.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.17.5",
    "sortablejs": "^1.15.7",
    "tailwindcss": "^4.1.18",
    "wrangler": "^4.56.0"
  }
}
